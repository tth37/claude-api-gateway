https://your-domain.example.com {
	log {
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}

	handle /status* {
		uri strip_prefix /status
		reverse_proxy 127.0.0.1:9123
	}

	handle {
		forward_auth http://127.0.0.1:9123 {
			uri /verify
			copy_headers X-Real-Authorization
		}

		reverse_proxy https://api.anthropic.com {
			header_up Authorization "{http.request.header.X-Real-Authorization}"
			header_up -X-Real-Authorization
			header_up -X-Forwarded-For
			header_up -X-Real-IP
			header_up -Forwarded
			header_up -X-Forwarded-Proto
			header_up -X-Forwarded-Host
			header_up -X-Forwarded-Port
			header_up -Via
			header_up -X-Api-Key
			header_up User-Agent "anthropic-sdk/1.0"
			header_up -X-Stainless-Os
			header_up -X-Stainless-Arch
			header_up -X-Stainless-Runtime
			header_up -X-Stainless-Runtime-Version
			header_up -X-Stainless-Package-Version
			header_up -X-Stainless-Lang
			header_up -X-Stainless-Retry-Count
			header_up -X-Stainless-Timeout
			header_up -X-App
			header_up -Anthropic-Dangerous-Direct-Browser-Access

			handle_response {
				header X-Debug-Token "{http.request.header.Authorization}"
				copy_response_headers
				copy_response
			}
		}
	}
}
